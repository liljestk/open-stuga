{
  "name": "@open-stuga/cloudflare",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "types": "wrangler types",
    "typecheck": "wrangler types --check && tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "migrate:local": "wrangler d1 migrations apply open-stuga --local",
    "migrate:remote": "wrangler d1 migrations apply open-stuga --remote",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "jose": "6.2.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "5.8.3",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
