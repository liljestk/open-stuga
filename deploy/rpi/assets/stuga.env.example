# Persistent Raspberry Pi appliance settings. Run `stugactl config` to edit.
# Container versions are pinned separately by each signed/hashed OS release.

# Secure default: reach the UI through an SSH tunnel to localhost:8080.
BIND_ADDRESS=127.0.0.1
APP_PORT=8080

# Set true only before the first start if you want disposable demo data.
MOCK_ENABLED=false

# Keep all bind-mounted state on the A/B shared persistent partition.
STUGA_CONFIG_DIRECTORY=/persistent/stuga/config
STUGA_BACKUP_DIRECTORY=/persistent/stuga/backups
STUGA_MIGRATION_DIRECTORY=/persistent/stuga/migrations
STUGA_MIGRATION_ENV_FILE=/persistent/stuga/stuga.env
STUGA_MIGRATION_SECRETS_DIRECTORY=/persistent/stuga/secrets
STUGA_CLOUDFLARE_SECRET_DIR=/persistent/stuga/secrets/cloudflare
STUGA_CLOUDFLARE_ENV_FILE=/persistent/stuga/secrets/cloudflare/config.env
TAPO_HISTORY_API_SECRET_DIR=/persistent/stuga/secrets/tapo-history-api
TAPO_HISTORY_RUNNER_SECRET_DIR=/persistent/stuga/secrets/tapo-history-runner
TAPO_RUNNER_FLOW_FILE=/persistent/stuga/config/tapo-flow.json

# Optional profiles, for example: cloudflare or tapo-history
COMPOSE_PROFILES=

# For deliberate LAN exposure, also set the exact browser origin, for example:
# BIND_ADDRESS=192.168.1.50
# CORS_ORIGIN=http://192.168.1.50:8080
CORS_ORIGIN=
LOCAL_AUTH_BOOTSTRAP_SECRET=
