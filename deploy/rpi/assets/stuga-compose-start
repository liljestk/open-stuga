#!/bin/bash
set -Eeuo pipefail

readonly project_dir=/opt/stuga
readonly state_dir=/persistent/stuga
readonly local_env="$state_dir/stuga.env"
readonly release_env="$project_dir/release.env"
readonly update_release_env="$state_dir/update-release/release.env"
readonly known_good_env="$state_dir/last-known-good.env"
readonly docker_config="$state_dir/docker-config"
readonly status_file="$state_dir/release-status"
readonly migration_health_authorization="$state_dir/migrations/.health-check-authorization"
readonly appliance_user=stuga
readonly lock_file=/run/lock/stuga-compose.lock

install -d -m 0750 -o "$appliance_user" -g "$appliance_user" "$state_dir"
install -d -m 0700 -o "$appliance_user" -g "$appliance_user" "$docker_config"
install -d -m 0750 -o "$appliance_user" -g "$appliance_user" \
  "$state_dir/backups" \
  "$state_dir/migrations" \
  "$state_dir/migrations/incoming" \
  "$state_dir/migrations/chunks" \
  "$state_dir/config" \
  "$state_dir/update-operations" \
  "$state_dir/update-release" \
  "$state_dir/secrets" \
  "$state_dir/secrets/cloudflare" \
  "$state_dir/secrets/tapo-history-api" \
  "$state_dir/secrets/tapo-history-runner"

# Never boot application containers over a partially mutated migration. The
# receipt is a write-ahead journal; an operator must finish rollback before the
# service can expose SQLite, WAL sidecars, settings, or database names.
authorized_pending_id=""
if [[ -f "$migration_health_authorization" && ! -L "$migration_health_authorization" ]]; then
  authorized_boot_id=""
  candidate_id=""
  read -r authorized_boot_id candidate_id < "$migration_health_authorization" || true
  rm -f "$migration_health_authorization"
  current_boot_id="$(cat /proc/sys/kernel/random/boot_id)"
  if [[ "$authorized_boot_id" == "$current_boot_id"
    && "$candidate_id" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$ ]]; then
    authorized_pending_id="${candidate_id,,}"
  fi
fi
shopt -s nullglob
for migration_receipt in "$state_dir"/migrations/receipts/*.json; do
  if grep -Eq '"status"[[:space:]]*:[[:space:]]*"(apply-intent|applying|rolling-back)"' \
      "$migration_receipt"; then
    echo "Refusing to start over incomplete migration receipt: $migration_receipt" >&2
    echo "Run 'stugactl migration status <id>' and 'stugactl migration rollback <id>'." >&2
    exit 1
  fi
  if grep -Eq '"status"[[:space:]]*:[[:space:]]*"applied-pending-health-check"' \
      "$migration_receipt"; then
    receipt_id="$(basename "$migration_receipt" .json)"
    if [[ "${receipt_id,,}" != "$authorized_pending_id" ]]; then
      echo "Refusing to start over an uncommitted migration: $migration_receipt" >&2
      echo "Run 'stugactl migration resume $receipt_id' after inspecting its health evidence." >&2
      exit 1
    fi
  fi
done

if [[ ! -e "$local_env" ]]; then
  install -m 0640 -o "$appliance_user" -g "$appliance_user" \
    "$project_dir/stuga.env.example" "$local_env"
fi

if [[ ! -e "$state_dir/config/tapo-flow.json" ]]; then
  install -m 0640 -o "$appliance_user" -g "$appliance_user" \
    "$project_dir/apps/tapo-export-runner/flow.example.json" \
    "$state_dir/config/tapo-flow.json"
fi

while IFS= read -r -d '' source_file; do
  destination="$state_dir/config/${source_file#"$project_dir/config/"}"
  if [[ ! -e "$destination" ]]; then
    install -d -m 0750 -o "$appliance_user" -g "$appliance_user" \
      "$(dirname "$destination")"
    install -m 0640 -o "$appliance_user" -g "$appliance_user" \
      "$source_file" "$destination"
  fi
done < <(find "$project_dir/config" -type f -print0)

exec 9>"$lock_file"
flock 9

compose() {
  local selected_release_env="$1"
  shift
  DOCKER_CONFIG="$docker_config" docker compose \
    --project-name stuga \
    --project-directory "$project_dir" \
    --env-file "$local_env" \
    --env-file "$selected_release_env" \
    --file "$project_dir/docker-compose.yml" \
    "$@"
}

valid_ui_release() {
  local candidate="$1"
  [[ -f "$candidate" && ! -L "$candidate" ]] || return 1
  [[ "$(wc -l < "$candidate")" -eq 6 ]] || return 1
  local version
  version="$(sed -n 's/^STUGA_VERSION=//p' "$candidate")"
  [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?$ ]] \
    && [[ "$(grep -c '^STUGA_VERSION=' "$candidate")" -eq 1 ]] \
    && grep -Fxq "STUGA_API_IMAGE=ghcr.io/liljestk/open-stuga-api:v$version" "$candidate" \
    && grep -Fxq "STUGA_WEB_IMAGE=ghcr.io/liljestk/open-stuga-web:v$version" "$candidate" \
    && grep -Fxq "STUGA_BACKUP_IMAGE=ghcr.io/liljestk/open-stuga-backup:v$version" "$candidate" \
    && grep -Fxq "STUGA_TAPO_RUNNER_IMAGE=ghcr.io/liljestk/open-stuga-tapo-export-runner:v$version" "$candidate" \
    && grep -Fxq "STUGA_UPDATE_AGENT_IMAGE=ghcr.io/liljestk/open-stuga-update-agent:v$version" "$candidate"
}

release_version() {
  sed -n 's/^STUGA_VERSION=//p' "$1" | tail -n 1
}

start_release() {
  local selected_release_env="$1"
  compose "$selected_release_env" up \
    --detach \
    --no-build \
    --pull never \
    --remove-orphans \
    --wait \
    --wait-timeout 600
}

selected_release_env="$release_env"
if valid_ui_release "$update_release_env"; then
  selected_release_env="$update_release_env"
fi

echo "Pulling the pinned Stuga release"
if ! compose "$selected_release_env" pull; then
  echo "Registry pull failed; attempting to use already-cached images" >&2
fi

if start_release "$selected_release_env"; then
  install -m 0640 -o "$appliance_user" -g "$appliance_user" \
    "$selected_release_env" "$known_good_env"
  {
    printf 'version=%s\n' "$(release_version "$selected_release_env")"
    printf 'healthy_at=%s\n' "$(date --utc +%Y-%m-%dT%H:%M:%SZ)"
  } > "$status_file"
  chown "$appliance_user:$appliance_user" "$status_file"
  chmod 0640 "$status_file"
  echo "Stuga $(release_version "$selected_release_env") is healthy"
  exit 0
fi

echo "The new release did not become healthy" >&2
if [[ -s "$known_good_env" ]] && ! cmp --silent "$selected_release_env" "$known_good_env"; then
  echo "Restoring the last known-good application containers" >&2
  if start_release "$known_good_env"; then
    printf 'failed_version=%s\nrolled_back_at=%s\n' \
      "$(release_version "$selected_release_env")" "$(date --utc +%Y-%m-%dT%H:%M:%SZ)" \
      > "$status_file"
    chown "$appliance_user:$appliance_user" "$status_file"
    chmod 0640 "$status_file"
    echo "The last known-good application release is running" >&2
    exit 0
  fi
fi

exit 1
