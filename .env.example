# Server
PORT=8787
API_HOST=127.0.0.1
# Docker publishes the web UI on loopback by default. Use a deliberate LAN address only after adding access controls.
BIND_ADDRESS=127.0.0.1
# Host-side port used by docker-compose.yml.
APP_PORT=8080
DATABASE_PATH=./data/climate-twin.sqlite
MOCK_ENABLED=true
MOCK_INTERVAL_MS=2000
RETENTION_DAYS=730
INGEST_API_KEY=
# Exact browser origin allowed to call a split-origin API. Leave empty for same-origin/local development.
CORS_ORIGIN=

# Optional Home Assistant bridge. Long-lived access tokens are never stored in SQLite.
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
HA_ENTITY_MAP_FILE=./config/home-assistant.entities.json

# Optional outbound webhooks (Home Assistant, OpenWearable, DayOps, etc.)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_BEARER_TOKEN=

# Web app (empty means same origin; Vite proxies /api in development)
VITE_API_BASE_URL=
