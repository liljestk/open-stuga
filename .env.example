# Server
PORT=8787
API_HOST=127.0.0.1
# Docker publishes the web UI on loopback by default. Use a deliberate LAN address only after adding access controls.
BIND_ADDRESS=127.0.0.1
# For an intentionally non-loopback first-owner setup, provide a random secret
# of at least 32 bytes and send it once as X-Stuga-Bootstrap-Secret.
LOCAL_AUTH_BOOTSTRAP_SECRET=
# Host-side port used by docker-compose.yml.
APP_PORT=8080
DATABASE_PATH=./data/climate-twin.sqlite
# Optional local-only research engine. Its disposable snapshots and rolling
# state are kept outside the core telemetry database.
SPATIAL_LAYERS_ENABLED=true
SPATIAL_LAYERS_DATABASE_PATH=./data/experimental-spatial-layers.sqlite
SPATIAL_LAYERS_INTERVAL_MS=60000
SPATIAL_LAYERS_RETENTION_DAYS=30
# Write-only credentials saved from the setup page live here, outside SQLite.
INTEGRATION_SECRETS_FILE=./data/integration-secrets.json
# Demo generation is opt-in. Set true before first start to create the sample
# home and sensors. Accepting real/API/import/FMI data permanently disables it.
MOCK_ENABLED=false
MOCK_INTERVAL_MS=2000
# Raw rows are retained in both SQLite and TimescaleDB. Positive local-copy
# pruning is deliberately rejected until every historical API path is archive-aware.
RETENTION_DAYS=0
INGEST_API_KEY=
# Custom electricity feeds are public-network HTTPS endpoints by default.
# Set true only for a deliberately trusted private-network feed; redirect and
# response-size protections remain active.
ELECTRICITY_ALLOW_PRIVATE_ENDPOINTS=false
# Exact browser origin allowed to call a split-origin API or a non-loopback
# same-origin deployment. Loopback localhost/127.0.0.1 needs no override.
CORS_ORIGIN=

# Optional durable time-series backend. Docker Compose enables this by default;
# local `npm run dev` remains a zero-dependency SQLite installation unless you
# opt in. Raw Timescale telemetry has no deletion/retention policy.
TIMESERIES_ENABLED=false
TIMESERIES_REQUIRED=false
TIMESERIES_HOST=127.0.0.1
TIMESERIES_PORT=5432
TIMESERIES_DATABASE=stuga
TIMESERIES_USER=stuga_app
# Configure either an inline password or a file, never both. Compose generates
# its application/admin credentials in the private runtime volume automatically.
TIMESERIES_PASSWORD=
TIMESERIES_PASSWORD_FILE=
# Internal Compose traffic uses disable on an isolated network. Use verify-full
# for an external server; optionally provide its private CA bundle.
TIMESERIES_SSL_MODE=disable
TIMESERIES_SSL_CA_FILE=
TIMESERIES_POOL_MAX=6
TIMESERIES_CONNECT_TIMEOUT_MS=5000
TIMESERIES_STATEMENT_TIMEOUT_MS=15000
TIMESERIES_BATCH_SIZE=1000

# Optional advanced overrides for credentials entered on the setup page.
# Environment values take precedence over the server-side secrets file after restart.
HA_URL=
HA_TOKEN=
HA_ENTITY_MAP_FILE=./config/home-assistant.entities.json

# Optional direct local TP-Link H100/H200 bridge (alternative to, or independent of, Home Assistant).
# Install apps/api/python/requirements.txt for local runs; the Docker image includes it.
TP_LINK_HOST=
TP_LINK_USERNAME=
TP_LINK_PASSWORD=
# Optional legacy bootstrap map. New mappings can be created in the Sensors workspace.
TP_LINK_DEVICE_MAP_FILE=./config/tp-link.devices.json
TP_LINK_POLL_INTERVAL_MS=10000
# Override only when Python 3 is not available as python/python3 on PATH.
TP_LINK_PYTHON=

# Optional outbound webhooks (Home Assistant, OpenWearable, DayOps, etc.)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_BEARER_TOKEN=

# Optional Telegram alerts. Prefer the guided Setup > Automations flow, which
# stores these write-only in INTEGRATION_SECRETS_FILE. Environment values are
# advanced deployment overrides. Create the token with @BotFather and use a
# private numeric chat id discovered by the setup wizard.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web app (empty means same origin; Vite proxies /api in development)
VITE_API_BASE_URL=
# Freshness windows used by 2D/3D spatial interpolation. Replay may use wider-spaced history.
VITE_SPATIAL_MAX_SAMPLE_AGE_MS=900000
VITE_SPATIAL_REPLAY_MAX_SAMPLE_AGE_MS=5400000
