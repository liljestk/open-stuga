# Server
PORT=8787
API_HOST=127.0.0.1
# Docker publishes the web UI on loopback by default. Use a deliberate LAN address only after adding access controls.
BIND_ADDRESS=127.0.0.1
# For an intentionally non-loopback first-owner setup, provide a random secret
# of at least 32 bytes and send it once as X-Stuga-Bootstrap-Secret.
LOCAL_AUTH_BOOTSTRAP_SECRET=
# Host-side port used by docker-compose.yml.
APP_PORT=8080
DATABASE_PATH=./data/climate-twin.sqlite
# Optional local-only research engine. Its disposable snapshots and rolling
# state are kept outside the core telemetry database.
SPATIAL_LAYERS_ENABLED=true
SPATIAL_LAYERS_DATABASE_PATH=./data/experimental-spatial-layers.sqlite
SPATIAL_LAYERS_INTERVAL_MS=60000
SPATIAL_LAYERS_RETENTION_DAYS=30
# Write-only credentials saved from the setup page live here, outside SQLite.
INTEGRATION_SECRETS_FILE=./data/integration-secrets.json
# Demo generation is opt-in. Set true before first start to create the sample
# home and sensors. Accepting real/API/import/FMI data permanently disables it.
MOCK_ENABLED=false
MOCK_INTERVAL_MS=2000
# Raw rows are retained in both SQLite and TimescaleDB. Positive local-copy
# pruning is deliberately rejected until every historical API path is archive-aware.
RETENTION_DAYS=0
INGEST_API_KEY=
# Custom electricity feeds are public-network HTTPS endpoints by default.
# Set true only for a deliberately trusted private-network feed; redirect and
# response-size protections remain active.
ELECTRICITY_ALLOW_PRIVATE_ENDPOINTS=false
# Exact browser origin allowed to call a split-origin API or a non-loopback
# same-origin deployment. Loopback localhost/127.0.0.1 needs no override.
CORS_ORIGIN=

# Optional Cloudflare Tunnel + Access deployment. `scripts/cloudflare-stuga.mjs`
# writes the generated IDs and least-privilege token-file paths to this ignored
# directory; do not put API or Tunnel tokens in .env.
STUGA_CLOUDFLARE_SECRET_DIR=./secrets/cloudflare
STUGA_CLOUDFLARE_ENV_FILE=./secrets/cloudflare/config.env
# Live system-to-system migration uses a private chunk cache plus explicit
# target mounts. The source controller transfers through authenticated SSH.
STUGA_MIGRATION_DIRECTORY=./data/migrations
STUGA_MIGRATION_ENV_FILE=./.env
STUGA_MIGRATION_SECRETS_DIRECTORY=./secrets
STUGA_MIGRATION_SEED_RETENTION_DAYS=14
STUGA_MIGRATION_MAX_RETAINED_SEEDS=4
# Stuga keeps the configured Cloudflare operator identities and reconciles all
# non-owner members plus unexpired invitations into one managed Access group.
# The provisioner writes CLOUDFLARE_ACCESS_STATIC_EMAILS from --owner-email.
# Existing generated configs must add the Cloudflare login address before
# upgrading; see docs/cloudflare-access.md. Comma-separate recovery operators.
CLOUDFLARE_ACCESS_STATIC_EMAILS=
# Immediate invite/removal sync is backed by this safety interval.
CLOUDFLARE_ACCESS_SYNC_INTERVAL_MS=300000
# Pinned by default in Compose; override only for a reviewed cloudflared release.
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.7.2

# Optional durable time-series backend. Docker Compose enables this by default;
# local `npm run dev` remains a zero-dependency SQLite installation unless you
# opt in. Raw Timescale telemetry has no deletion/retention policy.
TIMESERIES_ENABLED=false
TIMESERIES_REQUIRED=false
TIMESERIES_HOST=127.0.0.1
TIMESERIES_PORT=5432
TIMESERIES_DATABASE=stuga
TIMESERIES_USER=stuga_app
# Configure either an inline password or a file, never both. Compose generates
# its application/admin credentials in the private runtime volume automatically.
TIMESERIES_PASSWORD=
TIMESERIES_PASSWORD_FILE=
# Internal Compose traffic uses disable on an isolated network. Use verify-full
# for an external server; optionally provide its private CA bundle.
TIMESERIES_SSL_MODE=disable
TIMESERIES_SSL_CA_FILE=
TIMESERIES_POOL_MAX=6
TIMESERIES_CONNECT_TIMEOUT_MS=5000
TIMESERIES_STATEMENT_TIMEOUT_MS=15000
TIMESERIES_BATCH_SIZE=1000

# Optional advanced overrides for credentials entered on the setup page.
# Environment values take precedence over the server-side secrets file after restart.
HA_URL=
HA_TOKEN=
HA_ENTITY_MAP_FILE=./config/home-assistant.entities.json

# Optional direct local TP-Link H100/H200 bridge (alternative to, or independent of, Home Assistant).
# Install apps/api/python/requirements.txt for local runs; the Docker image includes it.
TP_LINK_HOST=
TP_LINK_USERNAME=
TP_LINK_PASSWORD=
# Optional legacy bootstrap map. New mappings can be created in the Sensors workspace.
TP_LINK_DEVICE_MAP_FILE=./config/tp-link.devices.json
TP_LINK_POLL_INTERVAL_MS=2000
# Override only when Python 3 is not available as python/python3 on PATH.
TP_LINK_PYTHON=

# Automated TP-Link/Tapo history recovery. Recent gaps use the local hub first;
# these settings enable the older app-export/mailbox fallback. Keep disabled
# until the isolated Android/Appium flow has been captured and canary-tested.
TAPO_HISTORY_ENABLED=false
# Non-Compose only: generate a random value of at least 32 bytes and configure
# one form. Compose generates and shares this token in a dedicated named volume.
TAPO_HISTORY_WORKER_TOKEN=
TAPO_HISTORY_WORKER_TOKEN_FILE=
# Dedicated mailbox with verified plus-address support (for example Gmail).
TAPO_HISTORY_EXPORT_EMAIL=
TAPO_HISTORY_EMAIL_TAG_PREFIX=stuga
# Tapo-supported values: 1, 15, 30, 60, 360, 720, or 1440 minutes.
TAPO_HISTORY_EXPORT_INTERVAL_MINUTES=15
TAPO_HISTORY_MAX_EXPORT_DAYS=30
TAPO_HISTORY_MAX_PENDING_EMAILS=1
TAPO_HISTORY_MAILBOX_POLL_INTERVAL_MS=60000
# A missing export email is retried after six hours (up to the job attempt cap).
TAPO_HISTORY_EMAIL_TIMEOUT_MS=21600000
TAPO_HISTORY_WORKER_LEASE_MS=300000

# Gmail REST OAuth (gmail.readonly). Configure all three or none. Password/IMAP
# credentials are deliberately unsupported. File forms are preferred for the
# client secret and refresh token. Inline/file entries below are for
# non-Compose operation; Compose uses the fixed filenames documented below.
TAPO_HISTORY_GMAIL_CLIENT_ID=
# Primary identity returned by Gmail /users/me/profile. Usually inferred from
# TAPO_HISTORY_EXPORT_EMAIL; set it for Workspace aliases or catch-all routing.
TAPO_HISTORY_GMAIL_ACCOUNT_EMAIL=
TAPO_HISTORY_GMAIL_CLIENT_SECRET=
TAPO_HISTORY_GMAIL_CLIENT_SECRET_FILE=
TAPO_HISTORY_GMAIL_REFRESH_TOKEN=
TAPO_HISTORY_GMAIL_REFRESH_TOKEN_FILE=

# Optional experimental adapter for a separately maintained reverse-engineered
# HTTPS endpoint. Its response must echo the device id and prove complete
# rangeStart/rangeEnd coverage. The inline/file token forms are non-Compose;
# Compose reads private-endpoint-token from the API secret directory.
TAPO_HISTORY_PRIVATE_ENDPOINT=
TAPO_HISTORY_PRIVATE_TOKEN=
TAPO_HISTORY_PRIVATE_TOKEN_FILE=

# Compose mounts two least-privilege host directories (both are git/docker
# ignored). Put gmail-client-secret, gmail-refresh-token, and optional
# private-endpoint-token in the API directory. Put account-email and
# account-password in the runner directory. The two containers cannot read one
# another's credentials. For a retained signed-in Tapo session, place a stable
# random account-proof (32+ bytes) in the runner directory instead of the two
# login files.
TAPO_HISTORY_API_SECRET_DIR=./secrets/tapo-history-api
TAPO_HISTORY_RUNNER_SECRET_DIR=./secrets/tapo-history-runner

# Android/Appium worker (normally enabled with the Compose tapo-history profile).
TAPO_RUNNER_ENABLED=false
TAPO_RUNNER_WORKER_ID=tapo-android-01
# Stable deployment-wide identifier for this one physical phone; required when enabled.
TAPO_TARGET_LOCK_ID=
TAPO_APPIUM_URL=http://host.docker.internal:4723
TAPO_APPIUM_CAPABILITIES_JSON={"platformName":"Android","appium:automationName":"UiAutomator2","appium:udid":"emulator-5554","appium:platformVersion":"CHANGE_ME","appium:language":"en","appium:locale":"GB","appium:noReset":true,"appium:newCommandTimeout":86400}
# Set true only after starting Appium >=2.18 with the repository log-filter
# file, protected log retention, and a firewall-limited bind address.
TAPO_APPIUM_LOGS_HARDENED=false
TAPO_APPIUM_VERSION=
TAPO_UIAUTOMATOR2_VERSION=
TAPO_APP_VERSION=
# Required safety attestation when enabled; use an automation-only Tapo account.
TAPO_DEDICATED_ACCOUNT=false
# Compose host path to the captured flow. The checked-in example is intentionally
# unusable and exists only so disabled-profile configuration remains valid.
TAPO_RUNNER_FLOW_FILE=./apps/tapo-export-runner/flow.example.json
TAPO_KEEP_SESSION_ON_SHUTDOWN=true
# Non-Compose runner forms; Compose reads account-email/account-password from
# TAPO_HISTORY_RUNNER_SECRET_DIR instead.
TAPO_ACCOUNT_EMAIL=
TAPO_ACCOUNT_PASSWORD=
TAPO_ACCOUNT_EMAIL_FILE=
TAPO_ACCOUNT_PASSWORD_FILE=
# Required instead of email/password for retained-session mode. This is a
# high-entropy operator attestation; it is HMAC-bound into canary approval.
TAPO_ACCOUNT_PROOF=
TAPO_ACCOUNT_PROOF_FILE=
TAPO_RUNNER_POLL_MS=10000
TAPO_RUNNER_HEARTBEAT_MS=15000
TAPO_RUNNER_REQUEST_TIMEOUT_MS=15000
TAPO_RUNNER_ARTIFACT_RETENTION_DAYS=30
TAPO_ACTION_TIMEOUT_MS=15000

# Optional outbound webhooks (Home Assistant, OpenWearable, DayOps, etc.).
# Use either the multi-destination JSON value or the legacy singleton tuple,
# never both. Destination ids must be stable lowercase identifiers.
ALERT_WEBHOOK_DESTINATIONS_JSON=
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_BEARER_TOKEN=
ALERT_WEBHOOK_SIGNING_SECRET=
# Exact comma-separated hosts. Empty derives the list from configured URLs.
ALERT_WEBHOOK_ALLOWED_HOSTS=

# Optional Telegram alerts. Prefer the guided Setup > Automations flow, which
# stores these write-only in INTEGRATION_SECRETS_FILE. Environment values are
# advanced deployment overrides. Create the token with @BotFather and use a
# private numeric chat id discovered by the setup wizard.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web app (empty means same origin; Vite proxies /api in development)
VITE_API_BASE_URL=
# Freshness windows used by 2D/3D spatial interpolation. Replay may use wider-spaced history.
VITE_SPATIAL_MAX_SAMPLE_AGE_MS=900000
VITE_SPATIAL_REPLAY_MAX_SAMPLE_AGE_MS=5400000
