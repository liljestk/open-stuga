{
  "name": "@climate-twin/web",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "tsc -b && vite build --configLoader runner",
    "preview": "vite preview --configLoader runner",
    "test": "vitest run --configLoader runner",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@climate-twin/contracts": "0.7.0",
    "@climate-twin/spatial-layers": "0.7.0",
    "@climate-twin/stugby-protocol": "0.7.0",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@vitejs/plugin-react": "^4.4.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "read-excel-file": "^9.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "jsdom": "^25.0.1",
    "vite": "^6.1.0",
    "vitest": "^4.1.10"
  }
}
