# The worker is inert until this is explicitly enabled; disabled mode does not
# validate or certify the required enabled-mode pins below.
TAPO_RUNNER_ENABLED=false

# Authenticated internal Stuga API. Use a dedicated, randomly generated token.
STUGA_API_URL=http://api:8787
TAPO_RUNNER_API_PREFIX=/api/v1/internal/tapo-history
TAPO_HISTORY_WORKER_TOKEN=
# File alternatives are preferred in containers; configure only one form.
TAPO_HISTORY_WORKER_TOKEN_FILE=
# Human-readable process label only. Lease/API identity is derived below.
TAPO_RUNNER_WORKER_ID=tapo-android-01
# Keep this stable across Appium hostname changes and never reuse it for another phone.
TAPO_TARGET_LOCK_ID=

# Appium 2.18+ endpoint and Android target. Pin the image locale/version; all
# fields below are included in the canary deployment fingerprint.
TAPO_APPIUM_URL=http://appium:4723
TAPO_APPIUM_CAPABILITIES_JSON={"platformName":"Android","appium:automationName":"UiAutomator2","appium:platformVersion":"15","appium:language":"en","appium:locale":"US","appium:udid":"emulator-5554","appium:noReset":true,"appium:newCommandTimeout":86400}
# Set true only after starting Appium with appium-log-filters.json and protected,
# rotated owner-only logs. Every enabled runner fails closed while this is false.
TAPO_APPIUM_LOGS_HARDENED=false
TAPO_APPIUM_VERSION=
TAPO_UIAUTOMATOR2_VERSION=
# Exact installed Tapo APK versionName/build pin; floating labels are rejected.
TAPO_APP_VERSION=
# Required when enabled: operator attestation that this account contains only
# automation targets with globally unique aliases. This is not runtime proof
# from Tapo; the calibrated flow must still verify deviceProofs[deviceId].
TAPO_DEDICATED_ACCOUNT=false
TAPO_APPIUM_SESSION_FILE=/data/tapo-appium-session.json
TAPO_KEEP_SESSION_ON_SHUTDOWN=true

# Copy flow.example.json, replace every CHANGE_ME selector using Appium Inspector,
# then point the runner at the tested copy.
TAPO_RUNNER_FLOW_CONFIG=/config/tapo-flow.json
TAPO_ACTION_TIMEOUT_MS=15000

# Login is optional when the persistent app session is already authenticated.
# If it is needed, inject these through a secret store, never a committed env file.
TAPO_ACCOUNT_EMAIL=
TAPO_ACCOUNT_PASSWORD=
TAPO_ACCOUNT_EMAIL_FILE=
TAPO_ACCOUNT_PASSWORD_FILE=
# Required instead of email/password when relying on a retained signed-in
# session. Generate a stable random per-account secret (32+ bytes). Its HMAC is
# fingerprinted; the proof itself is not logged, but remains operator attestation.
TAPO_ACCOUNT_PROOF=
TAPO_ACCOUNT_PROOF_FILE=

# This mailbox must support plus addressing and be monitored by the API importer.
TAPO_EXPORT_EMAIL=tapo-history@example.com

TAPO_RUNNER_POLL_MS=10000
TAPO_RUNNER_HEARTBEAT_MS=15000
TAPO_RUNNER_REQUEST_TIMEOUT_MS=15000
TAPO_RUNNER_ARTIFACT_DIR=/data/artifacts
TAPO_RUNNER_ARTIFACT_RETENTION_DAYS=30
