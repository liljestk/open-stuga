{
  "name": "@climate-twin/api",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "cd ../.. && tsx --env-file-if-exists=.env watch apps/api/src/index.ts",
    "start": "cd ../.. && node --env-file-if-exists=.env apps/api/dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "test:watch": "vitest",
    "mcp": "cd ../.. && tsx --env-file-if-exists=.env apps/api/src/mcp-server.ts"
  },
  "dependencies": {
    "@climate-twin/contracts": "*",
    "@climate-twin/spatial-layers": "*",
    "@climate-twin/stugby-protocol": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bonjour-service": "^1.4.3",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.10.1",
    "pg": "8.22.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "22.13.14",
    "@types/pg": "8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
